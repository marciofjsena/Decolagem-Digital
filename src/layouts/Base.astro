---
import { SITE } from '../config';

interface Props {
  titulo?: string;
  descricao?: string;
  noindex?: boolean;
}

const {
  titulo = SITE.titulo,
  descricao = SITE.descricao,
  noindex = false,
} = Astro.props;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{titulo}</title>
    <meta name="description" content={descricao} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descricao} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ---------------------------------------------------------------
     PALETA — extraida da logo do Projeto Decolagem Digital.
     Preto absoluto de fundo, laranja incandescente como acao,
     prata metalico para os titulos.
     --------------------------------------------------------------- */

  :root {
    /* fundos */
    --preto: #000000;
    --preto-carvao: #0b0b0c;
    --preto-caixa: #131315;
    --borda: #26262a;

    /* laranjas da logo */
    --laranja: #ff6a00;
    --laranja-claro: #ffa51f;
    --ambar: #ffd37a;

    /* textos */
    --texto: #f2f2f3;
    --prata: #c9ccd1;
    --suave: #8e9198;

    --erro: #ff8a7a;
    --sucesso: #48d17a;

    --largura: 34rem;
  }

  * {
    box-sizing: border-box;
  }

  html {
    -webkit-text-size-adjust: 100%;
    background: var(--preto);
  }

  body {
    margin: 0;
    background: var(--preto);
    color: var(--texto);
    font-family:
      system-ui,
      -apple-system,
      'Segoe UI',
      Roboto,
      sans-serif;
    font-size: 1.0625rem;
    line-height: 1.6;
    /* Brilho de "decolagem". Comeca abaixo do topo de proposito: assim a
       area da logo fica preto puro e o fundo preto dela nao vira um
       quadrado visivel. */
    background-image: radial-gradient(
      130% 45% at 50% 30%,
      rgba(255, 106, 0, 0.13) 0%,
      rgba(255, 106, 0, 0.035) 45%,
      transparent 72%
    );
    background-repeat: no-repeat;
    background-attachment: fixed;
  }

  main {
    max-width: var(--largura);
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  section {
    margin-top: 3.5rem;
  }

  h1 {
    font-size: 2rem;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin: 0 0 0.875rem;
    font-weight: 800;
  }

  h2 {
    font-size: 1.375rem;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin: 0 0 1rem;
    font-weight: 700;
  }

  h3 {
    font-size: 1rem;
    margin: 0 0 0.25rem;
    font-weight: 700;
    color: var(--texto);
  }

  p {
    margin: 0 0 1rem;
  }

  a {
    color: var(--laranja-claro);
  }

  strong {
    color: var(--texto);
  }

  /* Titulos com acabamento metalico, como na logo */
  .metal {
    background: linear-gradient(180deg, #ffffff 0%, #c9ccd1 55%, #8e9198 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .fogo {
    background: linear-gradient(180deg, var(--ambar) 0%, var(--laranja) 70%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .apoio {
    color: var(--suave);
  }

  .selo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ambar);
    border: 1px solid rgba(255, 106, 0, 0.35);
    background: rgba(255, 106, 0, 0.08);
    border-radius: 999px;
    padding: 0.3125rem 0.8125rem;
    margin-bottom: 1.25rem;
  }

  .selo::before {
    content: '';
    width: 0.4375rem;
    height: 0.4375rem;
    border-radius: 50%;
    background: var(--laranja);
    box-shadow: 0 0 8px var(--laranja);
  }

  .lista {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .lista li {
    padding: 0.9375rem 0;
    border-bottom: 1px solid var(--borda);
  }

  .lista li:last-child {
    border-bottom: none;
  }

  .lista p {
    margin: 0;
    color: var(--suave);
    font-size: 0.9375rem;
  }

  /* Lista com marcador de "risco de propulsao" laranja */
  .lista-risco li {
    position: relative;
    padding-left: 1.5rem;
  }

  .lista-risco li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.5rem;
    width: 0.75rem;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg, transparent, var(--laranja));
  }

  .caixa {
    background: var(--preto-caixa);
    border: 1px solid var(--borda);
    border-radius: 0.875rem;
    padding: 1.25rem;
  }

  footer {
    max-width: var(--largura);
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
    border-top: 1px solid var(--borda);
    color: var(--suave);
    font-size: 0.875rem;
  }

  footer a {
    color: var(--prata);
  }

  @media (min-width: 40rem) {
    h1 {
      font-size: 2.625rem;
    }
    main {
      padding-top: 3rem;
    }
  }
</style>

---
import { TEXTO_CONSENTIMENTO, SITE } from '../config';

interface Props {
  id: string;
  textoBotao?: string;
}

const { id, textoBotao = 'Entre para a comunidade no WhatsApp' } = Astro.props;
---

{/* O link da Comunidade viaja num atributo porque o codigo que roda no
    navegador (la embaixo) nao enxerga as variaveis daqui de cima. */}
<form
  class="formulario"
  data-formulario
  data-whatsapp={SITE.linkWhatsApp}
  id={id}
  novalidate
>
  <label>
    <span>Seu nome</span>
    <input
      type="text"
      name="nome"
      autocomplete="name"
      required
      maxlength="80"
      placeholder="Como você quer ser chamado"
    />
  </label>

  <label>
    <span>Seu melhor e-mail</span>
    <input
      type="email"
      name="email"
      autocomplete="email"
      inputmode="email"
      required
      maxlength="120"
      placeholder="voce@email.com"
    />
  </label>

  {/* Campo invisivel. Pessoas nao veem; robos preenchem e sao descartados. */}
  <div class="armadilha" aria-hidden="true">
    <label>
      Não preencha este campo
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <label class="consentimento">
    <input type="checkbox" name="consentimento" required />
    <span>{TEXTO_CONSENTIMENTO}</span>
  </label>

  <button type="submit">{textoBotao}</button>

  {/* Deixa explicito que tambem havera e-mail: evita a pessoa estranhar
      depois e marcar a mensagem como spam. */}
  <p class="aviso-email">Você também será avisado por e-mail sobre o lançamento.</p>

  <p class="recado" data-recado role="status" aria-live="polite"></p>

  {/* Rede de seguranca: so aparece se o WhatsApp nao abrir sozinho. */}
  <p class="socorro" data-socorro hidden>
    Não abriu?
    <a data-socorro-link href={SITE.linkWhatsApp} target="_blank" rel="noopener">
      Toque aqui para entrar na Comunidade
    </a>
  </p>
</form>

<style>
  .formulario {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--preto-caixa);
    border: 1px solid var(--borda);
    border-radius: 0.875rem;
    padding: 1.25rem;
    /* leve halo laranja, como o rastro da logo */
    box-shadow: 0 0 0 1px rgba(255, 106, 0, 0.06), 0 18px 40px -24px rgba(255, 106, 0, 0.5);
  }

  label > span {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
    color: var(--prata);
  }

  input[type='text'],
  input[type='email'] {
    width: 100%;
    /* 1rem evita que o iPhone de zoom automatico ao focar o campo */
    font-size: 1rem;
    font-family: inherit;
    padding: 0.8125rem 0.875rem;
    border: 1px solid var(--borda);
    border-radius: 0.5rem;
    background: var(--preto-carvao);
    color: var(--texto);
  }

  input[type='text']::placeholder,
  input[type='email']::placeholder {
    color: #5f636b;
  }

  input[type='text']:focus,
  input[type='email']:focus {
    border-color: var(--laranja);
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 106, 0, 0.18);
  }

  input:focus-visible {
    outline: none;
  }

  .armadilha {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .consentimento {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--suave);
    cursor: pointer;
  }

  .consentimento input {
    /* alvo grande o suficiente para o dedo no celular */
    width: 1.25rem;
    height: 1.25rem;
    margin: 0.125rem 0 0;
    flex-shrink: 0;
    accent-color: var(--laranja);
  }

  button {
    font-family: inherit;
    font-size: 1.0625rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    padding: 0.9375rem 1rem;
    border: none;
    border-radius: 0.5rem;
    background: linear-gradient(180deg, var(--laranja-claro) 0%, var(--laranja) 100%);
    color: #1a0d00;
    cursor: pointer;
    /* 44px minimo recomendado para toque */
    min-height: 3.25rem;
    box-shadow: 0 10px 24px -12px rgba(255, 106, 0, 0.85);
  }

  button:active {
    transform: translateY(1px);
  }

  button[disabled] {
    opacity: 0.55;
    cursor: progress;
    box-shadow: none;
  }

  .recado {
    margin: 0;
    font-size: 0.875rem;
    min-height: 1.25rem;
  }

  .recado:empty {
    min-height: 0;
  }

  .recado[data-tipo='erro'] {
    color: var(--erro);
  }

  .recado[data-tipo='sucesso'] {
    color: var(--sucesso);
  }

  .aviso-email {
    margin: -0.375rem 0 0;
    font-size: 0.75rem;
    color: var(--suave);
    text-align: center;
  }

  .socorro {
    margin: 0;
    font-size: 0.875rem;
    color: var(--suave);
    text-align: center;
  }

  .socorro a {
    color: var(--laranja-claro);
  }
</style>

<script>
  const TEXTO_BOTAO_SALVANDO = 'Salvando...';
  const TEXTO_BOTAO_ABRINDO = 'Abrindo a Comunidade...';
  // Se o WhatsApp nao assumir nesse tempo, mostramos o link de socorro.
  const ESPERA_ATE_SOCORRO = 2500;

  document.querySelectorAll<HTMLFormElement>('[data-formulario]').forEach((form) => {
    const botao = form.querySelector('button')!;
    const recado = form.querySelector<HTMLParagraphElement>('[data-recado]')!;
    const socorro = form.querySelector<HTMLParagraphElement>('[data-socorro]')!;
    const textoOriginal = botao.textContent ?? '';
    const linkWhatsApp = form.dataset.whatsapp ?? '';

    function mostrarErro(mensagem: string) {
      recado.textContent = mensagem;
      recado.dataset.tipo = 'erro';
    }

    function limparRecado() {
      recado.textContent = '';
      delete recado.dataset.tipo;
    }

    form.addEventListener('submit', async (evento) => {
      evento.preventDefault();
      limparRecado();

      const dados = new FormData(form);
      const nome = String(dados.get('nome') ?? '').trim();
      const email = String(dados.get('email') ?? '').trim();
      const consentimento = dados.get('consentimento') === 'on';
      const armadilha = String(dados.get('website') ?? '');

      if (!nome) {
        return mostrarErro('Escreva seu nome.');
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        return mostrarErro('Confira o e-mail: parece que falta algo.');
      }
      if (!consentimento) {
        return mostrarErro('Marque a caixinha de consentimento para continuar.');
      }

      botao.disabled = true;
      botao.textContent = TEXTO_BOTAO_SALVANDO;

      try {
        const resposta = await fetch('/api/inscrever', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            nome,
            email,
            consentimento,
            armadilha,
            origem: new URLSearchParams(location.search).get('origem') ?? '',
          }),
        });

        const resultado = await resposta.json().catch(() => null);

        if (resposta.ok && resultado?.ok) {
          // Segunda acao do botao: so agora, com o lead ja salvo, mandamos
          // a pessoa para a Comunidade. Na mesma aba de proposito — abrir
          // aba nova depois de uma espera e bloqueado no iPhone.
          botao.textContent = TEXTO_BOTAO_ABRINDO;
          recado.textContent = 'Cadastro confirmado. Levando você para a Comunidade...';
          recado.dataset.tipo = 'sucesso';

          setTimeout(() => {
            socorro.hidden = false;
          }, ESPERA_ATE_SOCORRO);

          location.href = linkWhatsApp;
          return;
        }

        mostrarErro(
          resultado?.mensagem ??
            'Não conseguimos enviar agora. Tente novamente em instantes.',
        );
      } catch {
        mostrarErro('Sem conexão. Confira sua internet e tente de novo.');
      }

      botao.disabled = false;
      botao.textContent = textoOriginal;
    });
  });
</script>

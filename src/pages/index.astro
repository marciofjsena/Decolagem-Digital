---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Formulario from '../components/Formulario.astro';
import logo from '../assets/logo.png';
import fotoHero from '../assets/marcio-hero.jpg';
import { SITE, HERO, APRENDIZADOS, PARA_QUEM, SOBRE } from '../config';
---

<Base>
  <main>
    {/* ---- 1. Logo + foto de fundo + chamada ---- */}
    <div class="topo-logo">
      <Image
        class="logo"
        src={logo}
        alt="Projeto Decolagem Digital — construa, escale e fature com IA"
        widths={[280, 560]}
        sizes="220px"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <section class="hero">
      <Image
        class="hero-foto"
        src={fotoHero}
        alt={`${SOBRE.nome}, na formatura de Engenharia Aeronáutica no ITA`}
        widths={[720, 1080, 1440]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero-scrim"></div>
      <div class="hero-texto">
        <span class="selo">{HERO.selo}</span>
        <h1>
          <span class="metal">{HERO.chamadaInicio}</span>{' '}
          <span class="fogo">{HERO.chamadaDestaque}</span>
        </h1>
        <p class="apoio">{HERO.apoio}</p>
      </div>
    </section>

    <section class="topo-form">
      <Formulario id="form-topo" />
    </section>

    {/* ---- 2. O que voce vai aprender ---- */}
    <section>
      <h2>O que você vai aprender</h2>
      <ul class="lista">
        {
          APRENDIZADOS.map((item) => (
            <li>
              <h3>{item.titulo}</h3>
              <p>{item.texto}</p>
            </li>
          ))
        }
      </ul>
    </section>

    {/* ---- 3. Para quem e ---- */}
    <section>
      <h2>Para quem é</h2>
      <ul class="lista lista-risco">
        {PARA_QUEM.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    {/* ---- 4. Quem esta por tras ---- */}
    <section>
      <h2>Quem vai te ensinar</h2>
      <div class="caixa">
        <h3>{SOBRE.nome}</h3>
        {SOBRE.texto.map((linha) => <p class="apoio">{linha}</p>)}
      </div>
    </section>
  </main>

  <footer>
    <p>{SITE.nomeCurso}</p>
    <p>
      <a href="/privacidade">Política de Privacidade</a>
      &nbsp;·&nbsp;
      <a href={`mailto:${SITE.emailContato}`}>{SITE.emailContato}</a>
    </p>
  </footer>
</Base>

<style>
  .topo-logo {
    text-align: center;
  }

  .logo {
    display: block;
    width: 11rem;
    max-width: 52%;
    height: auto;
    margin: 0 auto 1rem;
  }

  /* ---- HERO com a foto de fundo ----
     A secao ocupa a largura toda da tela (rompe a coluna central) e
     traz a foto como fundo. Um degrade escuro por cima escurece a parte
     de baixo o suficiente para o texto branco ser legivel e para a foto
     "derreter" no preto da pagina. */
  .hero {
    position: relative;
    /* rompe a coluna central e ocupa 100% da largura da tela */
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    min-height: 78vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-foto {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* mostra o rosto e o emblema do ITA; corta as cadeiras de baixo */
    object-position: center 18%;
    z-index: 0;
  }

  /* Escurece de cima (leve) para baixo (quase preto), com um toque de
     laranja no encontro com o resto da pagina, para amarrar a marca. */
  .hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(120% 55% at 50% 118%, rgba(255, 106, 0, 0.35) 0%, transparent 60%),
      linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.15) 0%,
        rgba(0, 0, 0, 0.35) 40%,
        rgba(0, 0, 0, 0.82) 72%,
        var(--preto) 100%
      );
  }

  .hero-texto {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--largura);
    margin: 0 auto;
    padding: 0 1.25rem 1.75rem;
  }

  .hero-texto h1 {
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.6);
  }

  .hero-texto .apoio {
    color: var(--prata);
    margin-bottom: 0;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.7);
  }

  .topo-form {
    margin-top: 1.5rem;
  }

  @media (min-width: 40rem) {
    .hero {
      min-height: 70vh;
    }
    .hero-foto {
      object-position: center 15%;
    }
  }
</style>

---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Formulario from '../components/Formulario.astro';
import logo from '../assets/logo.png';
import fotoMarcio from '../assets/marcio-ita.jpg';
import { SITE, HERO, APRENDIZADOS, PARA_QUEM, SOBRE } from '../config';
---

<Base>
  <main>
    {/* ---- 1. Chamada + formulario logo de cara ---- */}
    <section class="topo">
      <Image
        class="logo"
        src={logo}
        alt="Projeto Decolagem Digital — construa, escale e fature com IA"
        widths={[280, 560]}
        sizes="280px"
        loading="eager"
        fetchpriority="high"
      />

      <span class="selo">{HERO.selo}</span>
      <h1>
        <span class="metal">{HERO.chamadaInicio}</span>{' '}
        <span class="fogo">{HERO.chamadaDestaque}</span>
      </h1>
      <p class="apoio">{HERO.apoio}</p>

      <Formulario id="form-topo" />
    </section>

    {/* ---- 2. O que voce vai aprender ---- */}
    <section>
      <h2>O que você vai aprender</h2>
      <ul class="lista">
        {
          APRENDIZADOS.map((item) => (
            <li>
              <h3>{item.titulo}</h3>
              <p>{item.texto}</p>
            </li>
          ))
        }
      </ul>
    </section>

    {/* ---- 3. Para quem e ---- */}
    <section>
      <h2>Para quem é</h2>
      <ul class="lista lista-risco">
        {PARA_QUEM.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    {/* ---- 4. Quem esta por tras ---- */}
    <section>
      <h2>Quem vai te ensinar</h2>
      <div class="caixa autoridade">
        <div class="moldura">
          <Image
            class="retrato"
            src={fotoMarcio}
            alt={`${SOBRE.nome}, na formatura de Engenharia Aeronáutica no ITA`}
            widths={[640, 1280]}
            sizes="(min-width: 40rem) 60rem, 170vw"
            loading="lazy"
          />
        </div>
        <div class="autoridade-texto">
          <h3>{SOBRE.nome}</h3>
          {SOBRE.texto.map((linha) => <p class="apoio">{linha}</p>)}
        </div>
      </div>
    </section>

    {/* ---- 5. Formulario de novo, para quem rolou ate aqui ---- */}
    <section>
      <h2>Entre na lista de espera</h2>
      <p class="apoio">
        As vagas da primeira turma são limitadas. Quem está na lista é avisado antes de
        todo mundo.
      </p>
      <Formulario id="form-fim" />
    </section>
  </main>

  <footer>
    <p>{SITE.nomeCurso}</p>
    <p>
      <a href="/privacidade">Política de Privacidade</a>
      &nbsp;·&nbsp;
      <a href={`mailto:${SITE.emailContato}`}>{SITE.emailContato}</a>
    </p>
  </footer>
</Base>

<style>
  .topo {
    margin-top: 0;
  }

  .logo {
    display: block;
    width: 13.5rem;
    max-width: 62%;
    height: auto;
    margin: 0 auto 1.25rem;
  }

  /* A foto vira o topo da caixa, sem moldura entre ela e a borda */
  .autoridade {
    padding: 0;
    overflow: hidden;
  }

  /* A foto original e larga e ele aparece pequeno, com muita cadeira vazia
     embaixo. A moldura recorta: aproxima 1,8x e sobe o enquadramento,
     mantendo o rosto e o emblema do ITA e cortando o chao. */
  .moldura {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    border-bottom: 1px solid var(--borda);
  }

  .retrato {
    position: absolute;
    display: block;
    width: 180%;
    height: auto;
    left: -40%;
    top: -18%;
  }

  .autoridade-texto {
    padding: 1.25rem;
  }

  .autoridade-texto p:last-child {
    margin-bottom: 0;
  }

</style>
